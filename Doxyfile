# Doxyfile - konfiguracja dokumentacji Doxygen
# Analizator Danych Fizycznych
# Autor: Bartosz Woźnica

#---------------------------------------------------------------------------
# Konfiguracja projektu
#---------------------------------------------------------------------------

PROJECT_NAME           = "Analizator Danych Fizycznych"
PROJECT_NUMBER         = "1.0.0"
PROJECT_BRIEF          = "Aplikacja do analizy danych fizycznych z wykorzystaniem AI"
PROJECT_LOGO           = 

OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = Polish
TIMESTAMP              = YES
SORT_BRIEF_DOCS        = YES

#---------------------------------------------------------------------------
# Konfiguracja wejścia
#---------------------------------------------------------------------------

INPUT                  = . \
                         api \
                         compute \
                         config \
                         core \
                         data \
                         gui \
                         utils

FILE_PATTERNS          = *.py
RECURSIVE              = YES
EXCLUDE                = __pycache__ \
                         logs \
                         sample_data \
                         docs \
                         tools \
                         .git

#---------------------------------------------------------------------------
# Parsowanie Pythona
#---------------------------------------------------------------------------

EXTENSION_MAPPING      = py=Python
OPTIMIZE_OUTPUT_JAVA   = NO
PYTHON_DOCSTRING       = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = NO

#---------------------------------------------------------------------------
# Konfiguracja wyjścia
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = AUTO_LIGHT

GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO

#---------------------------------------------------------------------------
# Diagramy i grafy
#---------------------------------------------------------------------------

HAVE_DOT               = NO
COLLABORATION_GRAPH    = NO
INCLUDE_GRAPH          = NO
INCLUDED_BY_GRAPH      = NO

#---------------------------------------------------------------------------
# Preprocessing
#---------------------------------------------------------------------------

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO

#---------------------------------------------------------------------------
# Źródła
#---------------------------------------------------------------------------

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

#---------------------------------------------------------------------------
# Indeks
#---------------------------------------------------------------------------

ALPHABETICAL_INDEX     = YES
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO

#---------------------------------------------------------------------------
# Ostrzeżenia
#---------------------------------------------------------------------------

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES

